{% extends 'base.html.twig' %}

{% block title %}Hello LivresController!{% endblock %}

{% block body %}
    <h1>Détail du livre</h1>
    <div class="row">
        <div class="col-3">
         <div class="card">
             <div class="card-header">
                 <H5>{{ livre.titre|capitalize }} ({{livre.prix }}DT)</H5>
             </div>
             <div class="card-body">
                 <img src="{{ livre.image }}" class="img-fluid" alt="photo">
             </div>
         </div>
        </div>
        <div class="col">
            <H5>Editeur:{{ livre.editeur }}</H5>
            <H5>Date Edition:{{ livre.dateEdition|date('d-m-Y') }}</H5>
          <p>{{ livre.resume }}</p>
            {% if livre.qte!=0 %}
                <span class="badge bg-success">Quantité disponible: {{ livre.qte }}</span>
                {% else %}
                    <span class="badge bg-danger">En repture de stock!!!</span>

            {% endif %}
        </div>
    </div>
{% endblock %}
