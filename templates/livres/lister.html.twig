{% extends 'base.html.twig' %}

{% block title %}Hello LivresController!{% endblock %}

{% block body %}
    <h1>Liste des livres</h1>
    <table class="table">
        <tr class="table-primary">
            <th>Titre</th>
            <th>ISBN</th>
            <th>Editeur</th>
            <th>Date Edition</th>
            <th>Prix</th>
            <th colspan="3">Action</th>
        </tr>
        {% for livre in livres %}
            <tr>
                <td>{{ livre.titre}}</td>
                <td>{{ livre.isbn}}</td>
                <td>{{ livre.editeur}}</td>
                <td>{{ livre.dateEdition|date('d-m-Y')}}</td>
                <td>{{ livre.prix}}</td>
                <td><a href="{{ url('livres_show',{'id':livre.id}) }}">Voir détail...</a></td>
                <td><a href="#">Editer</a></td>
                <td><a href="#">Supprimer</a></td>
            </tr>
        {% endfor %}
    </table>

{% endblock %}
